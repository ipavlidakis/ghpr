+  fileprivate struct Combined: ParsableCommand {
+    @OptionGroup(title: "Extras")
+    var flags: Flags
+    
+    @OptionGroup(title: "Extras")
+    var options: Options
+    
+    @OptionGroup(title: "Others")
+    var flagsAndOptions: FlagsAndOptions
+    
+    @OptionGroup(title: "Others")
+    var argsAndFlags: ArgsAndFlags
+  }
