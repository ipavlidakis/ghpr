+
+      """)
+    
+    AssertHelp(.hidden, for: HiddenGroups.self, equals: """
+      USAGE: hidden-groups [--verbose] [--oversharing] [--name <name>] --age <age> [--experimental] --prefix <prefix>
+
+      FLAGS GROUP:
+        --verbose               example
+        --oversharing           example
+
+      OPTIONS GROUP:
+        --name <name>           example
+        --age <age>             example
+
+      OPTIONS:
+        --experimental          example
